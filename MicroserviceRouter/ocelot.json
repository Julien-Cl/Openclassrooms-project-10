{
    "Routes": [
        {
            "DownstreamPathTemplate": "/patients",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "patient-backend",
                    "Port": 8080
                }
            ],
            "UpstreamPathTemplate": "/patients",
            "UpstreamHttpMethod": [ "Get", "Post" ]
        },
        {
            "DownstreamPathTemplate": "/patients/{id}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "patient-backend",
                    "Port": 8080
                }
            ],
            "UpstreamPathTemplate": "/patients/{id}",
            "UpstreamHttpMethod": [ "Get", "Put", "Delete" ]
        },
        {
            "DownstreamPathTemplate": "/Auth/login",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "auth-backend",
                    "Port": 8080
                }
            ],
            "UpstreamPathTemplate": "/Auth/login",
            "UpstreamHttpMethod": [ "Post" ]
        },
        {
            "DownstreamPathTemplate": "/Auth/register",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "auth-backend",
                    "Port": 8080
                }
            ],
            "UpstreamPathTemplate": "/Auth/register",
            "UpstreamHttpMethod": [ "Post" ]
        },
        {
            "DownstreamPathTemplate": "/notes",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "note-backend",
                    "Port": 8080
                }
            ],
            "UpstreamPathTemplate": "/notes",
            "UpstreamHttpMethod": [ "Get", "Post" ]
        },
        {
            "DownstreamPathTemplate": "/notes/patient/{patientId}",
            "DownstreamScheme": "http",
            "DownstreamHostAndPorts": [
                {
                    "Host": "note-backend",
                    "Port": 8080
                }
            ],
            "UpstreamPathTemplate": "/notes/patient/{patientId}",
            "UpstreamHttpMethod": [ "Get" ]
        }
    ],
    "GlobalConfiguration": {
        "BaseUrl": "http://localhost:7001"
    }
}